# ============================================================
# SentinelArena Environment Configuration
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# --- Database ---
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=sentinel_arena
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://sentinel:CHANGE_ME_IN_PRODUCTION@postgres:5432/sentinel_arena

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Anthropic (LLM Provider) ---
# Leave empty to use mock LLM adapter for development
ANTHROPIC_API_KEY=
# Model for intent classification / routing (faster, cheaper)
ANTHROPIC_FAST_MODEL=claude-sonnet-4-20250514
# Model for complex reasoning (Decision Agent)
ANTHROPIC_REASONING_MODEL=claude-sonnet-4-20250514

# --- Weather API ---
# Leave empty to use mock weather adapter
WEATHER_API_KEY=
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# --- Crowd Simulator ---
SIMULATOR_INTERVAL_MS=5000
SIMULATOR_NUM_ZONES=12
SIMULATOR_MAX_CAPACITY_PER_ZONE=500

# --- Application ---
API_GATEWAY_PORT=8000
CROWD_SIMULATOR_PORT=8001
AGENT_ORCHESTRATOR_PORT=8002
WEB_DASHBOARD_PORT=3000
FAN_PWA_PORT=3001
VOLUNTEER_APP_PORT=3002

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_LLM_REQUESTS_PER_MINUTE=20

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=json
