{
  "name": "sentinel-arena",
  "version": "1.0.0",
  "private": true,
  "description": "GenAI-Powered Smart Stadium & Tournament Operations Platform",
  "author": "SentinelArena Team",
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:dashboard": "pnpm --filter @sentinel/web-dashboard dev",
    "dev:fan": "pnpm --filter @sentinel/fan-pwa dev",
    "dev:volunteer": "pnpm --filter @sentinel/volunteer-app dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "test:e2e": "pnpm exec playwright test",
    "test:a11y": "pnpm exec playwright test --project=accessibility",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "prepare": "husky",
    "clean": "pnpm -r run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yaml,yml}": [
      "prettier --write"
    ],
    "*.py": [
      "ruff check --fix",
      "ruff format"
    ]
  }
}
